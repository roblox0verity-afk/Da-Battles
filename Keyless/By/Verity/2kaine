end

-- CREATE GLOW
local function CreateGlow()
    if Glow then Glow:Destroy() end
    Glow = Instance.new("Highlight")
    Glow.Name = "Verity_Glow"
    Glow.FillColor = Settings.GlowColor
    Glow.OutlineColor = Color3.new(1, 1, 1)
    Glow.FillTransparency = 0.55
    Glow.OutlineTransparency = 0.3
    Glow.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    Glow.Enabled = false
    Glow.Parent = Workspace
end

-- UPDATE TRIANGLE
local function UpdateTriangle()
    if not Enabled or not Triangle or not CurrentTarget then
        Triangle.Transparency = 1
        return
    end
    local root = CurrentTarget.HumanoidRootPart
    if not root then Triangle.Transparency = 1 return end
    TriangleAngle = TriangleAngle + Settings.TriangleSpeed
    local offsetX = math.cos(math.rad(TriangleAngle)) * Settings.TriangleOrbitRadius
    local offsetZ = math.sin(math.rad(TriangleAngle)) * Settings.TriangleOrbitRadius
    Triangle.CFrame = CFrame.new(root.Position + Vector3.new(offsetX, Settings.TriangleHeight, offsetZ), Camera.CFrame.Position) * CFrame.Angles(math.rad(90), 0, 0)
    Triangle.Transparency = 0.22
end

-- UPDATE GLOW
local function UpdateGlow()
    if not CurrentTarget or not Glow then Glow.Enabled = false return end
    Glow.Adornee = CurrentTarget.Character
    Glow.Enabled = true
end

-- AIM POINT WITH DA HOOD OFFSETS
local function GetAimPoint(char, dist)
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    if not root or not torso then return nil end
    if dist < 180 then
        return torso.Position + DaHoodOffsets.UpperTorso
    elseif dist < 450 then
        return torso.Position + DaHoodOffsets.Torso
    else
        return root.Position + DaHoodOffsets.LowerTorso
    end
end

-- FIND TARGET
local function GetTarget()
    if not Enabled then CurrentTarget = nil return end
    local best, minDist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if not plr.Character then continue end
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        local root = plr.Character:FindFirstChild("HumanoidRootPart")
        if not hum or not root or hum.Health <= 0 then continue end
        local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
        if not onScreen or screenPos.Z < 1 then continue end
        if not IsVisible(root) then continue end
        local dist = (Camera.CFrame.Position - root.Position).Magnitude
        if dist > Settings.MaxDistance then continue end
        if dist < minDist then
            minDist = dist
            best = {
                Player = plr,
                Character = plr.Character,
                HumanoidRootPart = root,
                Distance = dist,
                Humanoid = hum
            }
        end
    end
    CurrentTarget = best
end

-- UPDATE STATUS & HIT LOGIC
local function UpdateStatus()
    if not CurrentTarget then
        AvatarImg.Visible = false
        StatusText.Visible = false
        Glow.Enabled = false
        return
    end
    local plr = CurrentTarget.Player
    local hum = CurrentTarget.Humanoid
    local hp = math.floor(hum.Health)
    local maxHp = math.floor(hum.MaxHealth)

    AvatarImg.Visible = true
    StatusText.Visible = true
    AvatarImg.Image = "https://www.roblox.com/headshot-thumbnail/image?userId="..plr.UserId.."&width=100&height=100&format=png"
    StatusText.Text = string.format("Name: %s\nDistance: %d studs\nHealth: %d / %d", plr.DisplayName, math.floor(CurrentTarget.Distance), hp, maxHp)

    if LastHealth[plr.UserId] then
        local diff = LastHealth[plr.UserId] - hp
        if diff >= Settings.SoundEveryXHP then
            PlayHealthSound()
            ShowHitIndicator()
            LastHealth[plr.UserId] = hp
        end
    else
        LastHealth[plr.UserId] = hp
    end
end


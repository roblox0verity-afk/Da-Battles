-- DA HOOD REAL FIRE
local function FireDaHoodWeapon()
    pcall(function()
        local fireRemote = ReplicatedStorage:FindFirstChild("FireGun") or ReplicatedStorage:FindFirstChild("WeaponEvent") or (ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Fire"))
        if fireRemote and fireRemote:IsA("RemoteEvent") then
            fireRemote:FireServer()
        else
            local tool = LocalCharacter:FindFirstChildOfClass("Tool")
            if tool then
                if tool:FindFirstChild("Fire") and tool.Fire:IsA("RemoteFunction") then
                    tool.Fire:InvokeServer()
                elseif tool:FindFirstChild("OnServerEvent") then
                    tool.OnServerEvent:FireServer("Fire")
                end
            end
        end
    end)
end

-- AUTO SHOOT
local function AutoShoot()
    if not Enabled or not Settings.AutoShootEnabled or not CurrentTarget then return end
    local hum = CurrentTarget.Humanoid
    if not hum then return end

    if hum.Health <= 0 then
        local dist = (LocalRoot.Position - CurrentTarget.HumanoidRootPart.Position).Magnitude
        OnPlayerDied(CurrentTarget.Player, dist)
        return
    end

    local now = os.clock()
    if now - LastShootTime < GetShootDelay() then return end

    if CurrentTarget.Distance <= Settings.ShootRange and IsVisible(CurrentTarget.HumanoidRootPart) then
        FireDaHoodWeapon()
        LastShootTime = now
    end
end


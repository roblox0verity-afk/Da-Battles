    Glow.Adornee = CurrentTarget.Character
    Glow.Enabled = true
end

-- AIM POINT WITH ANTI-DETECTION
local function GetAimPoint(char, dist)
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    if not root or not torso then return nil end

    local basePos
    if dist < 180 then
        basePos = torso.Position + DaHoodOffsets.UpperTorso
    elseif dist < 450 then
        basePos = torso.Position + DaHoodOffsets.Torso
    else
        basePos = root.Position + DaHoodOffsets.LowerTorso
    end

    -- Add humanized offset only
    if Settings.AntiDetection then
        basePos = basePos + AimOffset
    end

    return basePos
end

-- FIND BEST TARGET
local function GetTarget()
    local best, bestScore = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if not hum or not root or hum.Health <= 0 then continue end
        if hum.Health < Settings.MinTargetHP then continue end

        local aimPos = GetAimPoint(char, (Camera.CFrame.Position - root.Position).Magnitude)
        local dist = (Camera.CFrame.Position - aimPos).Magnitude
        if dist > Settings.MaxDistance then continue end
        if not IsInFOV(aimPos) then continue end
        if not IsVisible(root) then continue end

        local camDir = Camera.CFrame.LookVector
        local toTarget = (aimPos - Camera.CFrame.Position).Unit
        local angleDiff = math.deg(math.acos(math.clamp(camDir:Dot(toTarget), -1, 1)))
        local score = dist + (angleDiff * 2)

        if score < bestScore then
            bestScore = score
            best = {
                Player = plr,
                Character = char,
                Humanoid = hum,
                HumanoidRootPart = root,
                AimPos = aimPos,
                Distance = dist
            }
        end
    end
    return best
end

-- UPDATE STATUS
local function UpdateStatus()
    if not CurrentTarget then
        AvatarImg.Visible = false
        StatusText.Visible = false
        Glow.Enabled = false
        return
    end
    local plr = CurrentTarget.Player
    local hum = CurrentTarget.Humanoid
    local hp = math.floor(hum.Health)
    local maxHp = math.floor(hum.MaxHealth)

    AvatarImg.Visible = true
    StatusText.Visible = true
    AvatarImg.Image = string.format("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=100&height=100&format=png", plr.UserId)
    StatusText.Text = string.format("Name: %s\nDistance: %d studs\nHealth: %d / %d", plr.DisplayName, math.floor(CurrentTarget.Distance), hp, maxHp)

    if LastHealth[plr.UserId] then
        local diff = LastHealth[plr.UserId] - hp
        if diff >= Settings.SoundEveryXHP then
            PlayHealthSound()
            ShowHitIndicator()
        end
    end
    LastHealth[plr.UserId] = hp
end


    Triangle = Instance.new("Part")
    Triangle.Name = "Verity_Triangle"
    Triangle.Shape = Enum.PartType.Block
    Triangle.Size = Vector3.new(Settings.TriangleThickness, Settings.TriangleSize, Settings.TriangleSize)
    Triangle.Color = Settings.TriangleColor
    Triangle.Transparency = 0.22
    Triangle.CanCollide = false
    Triangle.Anchored = true

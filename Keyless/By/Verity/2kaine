-- PLAY HEALTH SOUND
local function PlayHealthSound()
    pcall(function()
        local s = Instance.new("Sound", SoundService)
        s.SoundId = Settings.HealthSound
        s.Volume = 0.85
        s:Play()
        task.delay(1, function() s:Destroy() end)
    end)
end

-- ✅ AUTO SHOOT: REAL Da Hood Fire, no taps
local function AutoShoot()
    if not Enabled or not Settings.AutoShootEnabled or not CurrentTarget then return end
    local hum = CurrentTarget.Humanoid
    if not hum or hum.Health <= 0 then return end -- Stop if dead

    local now = os.clock()
    if now - LastShootTime < Settings.ShootInterval then return end

    -- Only fire if in range + visible
    if CurrentTarget.Distance <= Settings.ShootRange and IsVisible(CurrentTarget.HumanoidRootPart) then
        FireDaHoodWeapon() -- Uses game's actual fire method
        LastShootTime = now
    end
end

-- CREATE ARROW
local function CreateArrow()
    Arrow = Instance.new("ImageLabel")
    Arrow.Name = "TargetArrow"
    Arrow.Size = UDim2.new(0, Settings.ArrowSize, 0, Settings.ArrowSize)
    Arrow.BackgroundTransparency = 1
    Arrow.Image = "rbxassetid://603481837"
    Arrow.ImageColor3 = Settings.ArrowColor
    Arrow.Visible = false
    Arrow.ZIndex = 9999
    Arrow.Parent = ScreenGui
end

-- UPDATE ARROW
local function UpdateArrow()
    if not CurrentTarget or not Arrow then Arrow.Visible = false return end
    local root = CurrentTarget.HumanoidRootPart
    if not root then Arrow.Visible = false return end
    local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
    Arrow.Visible = not onScreen
    if not onScreen then
        local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        local dir = Vector2.new(screenPos.X, screenPos.Y) - center
        Arrow.Position = UDim2.new(0.5, -Arrow.Size.X.Offset/2, 0.5, -Arrow.Size.Y.Offset/2)
        Arrow.Rotation = math.deg(math.atan2(dir.Y, dir.X))
    end
end


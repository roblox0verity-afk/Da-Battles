-- DA HOOD OFFSETS
local DaHoodOffsets = {
    UpperTorso = Vector3.new(0, 1.1, 0),
    Torso = Vector3.new(0, 0.9, 0),
    LowerTorso = Vector3.new(0, 0.5, 0)
}

-- SETTINGS
local Enabled = false
local Settings = {
    MaxDistance = 900,
    HealthSound = "rbxassetid://80461265049096",
    NotifyIcon = "rbxassetid://93474154889321",
    SoundEveryXHP = 2,
    -- Auto-Shoot
    AutoShootEnabled = true,
    ShootRange = 20, -- Only fire within 20 studs
    ShootInterval = 0.5, -- Matches weapon fire rate
    -- Visuals
    TriangleSize = 2.4,
    TriangleThickness = 0.4,
    TriangleColor = Color3.new(1, 0, 0),
    TriangleSpeed = 2.8,
    TriangleOrbitRadius = 3.8,
    TriangleHeight = 2.2,
    GlowColor = Color3.new(1, 0.2, 0.2),
    ArrowSize = 45,
    ArrowColor = Color3.new(1, 0, 0)
}

-- STORAGE
local ScreenGui = nil
local AvatarImg = nil
local StatusText = nil
local HitIndicator = nil
local Arrow = nil
local CurrentTarget = nil
local LastHealth = {}
local Triangle = nil
local Glow = nil
local TriangleAngle = 0
local LastShootTime = 0

-- ✅ DA HOOD FIRE REMOTE / FUNCTION (proper method, not taps)
local function FireDaHoodWeapon()
    pcall(function()
        -- Find Da Hood's main weapon remote
        local fireRemote = ReplicatedStorage:FindFirstChild("FireGun") or ReplicatedStorage:FindFirstChild("WeaponEvent") or ReplicatedStorage:WaitForChild("Remotes", 2):FindFirstChild("Fire")
        if fireRemote and fireRemote:IsA("RemoteEvent") then
            fireRemote:FireServer()
        else
            -- Fallback: direct weapon fire method if remote not found
            local tool = LocalCharacter:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Fire") then
                tool:FindFirstChild("Fire"):InvokeServer()
            elseif tool and tool:FindFirstChild("OnServerEvent") then
                tool.OnServerEvent:FireServer("Fire")
            end
        end
    end)
end

-- NOTIFY
local function Notify(msg)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "Verity",
            Text = msg,
            Duration = 2,
            Icon = Settings.NotifyIcon
        })
    end)
end

-- WALL CHECK
local function IsVisible(targetPart)
    if not targetPart then return false end
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {LocalCharacter, Camera}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.IgnoreWater = true
    local rayResult = Workspace:Raycast(Camera.CFrame.Position, targetPart.Position - Camera.CFrame.Position, rayParams)
    return not rayResult or rayResult.Instance:IsDescendantOf(targetPart.Parent)
end

-- CREATE HIT INDICATOR

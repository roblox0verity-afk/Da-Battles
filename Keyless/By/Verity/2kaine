-- PLAY SOUND
local function PlaySound(soundId, volume)
    volume = volume or 0.8
    return pcall(function()
        local s = Instance.new("Sound", SoundService)
        s.SoundId = soundId
        s.Volume = volume
        s:Play()
        task.delay(8, function() pcall(function() s:Destroy() end) end)
        return s
    end)
end

-- DEATH TRIGGER
local function OnPlayerDied(victim, distance)
    if distance > Settings.DeathMaxRange then return end
    if LastProcessedDeath == victim.UserId then return end
    LastProcessedDeath = victim.UserId

    PlaySound(Settings.DeathSound, 1)
    DeathText.Visible = true
    DeathText.Text = ">:)"
    DeathText.TextColor3 = Color3.new(1, 0.2, 0.2)
    DeathText.TextTransparency = 0

    task.wait(Settings.FaceDuration)
    PlaySound(Settings.SorrySound, 0.9)
    DeathText.Text = "sorry lol"
    DeathText.TextColor3 = Color3.new(1, 1, 1)

    task.wait(Settings.SorryDuration)
    PlaySound(Settings.FadeSound, 0.7)
    TweenService:Create(DeathText, TweenInfo.new(1), {TextTransparency = 1}):Play()

    task.wait(1.2)
    DeathText.Visible = false
    DeathText.TextTransparency = 0
end


-- WALL CHECK
local function IsVisible(part)
    if not part then return false end
    local ray = RaycastParams.new()
    ray.FilterDescendantsInstances = {LocalCharacter, Camera}
    ray.FilterType = Enum.RaycastFilterType.Exclude
    local result = Workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, ray)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

-- PREDICTION CALCULATION
local function GetPredictedPosition(targetPos, targetVel, dist)
    local time = math.min(dist / PredictionSettings.BulletSpeed, PredictionSettings.MaxPredictionTime)
    return targetPos + targetVel * time + Vector3.new(0, -PredictionSettings.Gravity * time * time / 2, 0)
end

-- GET AIM POINT
local function GetAimPoint(char, dist, vel)
    if not char then return nil end
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    if not torso then return nil end

    local basePos
    if dist < 200 then
        basePos = torso.Position + DaHoodOffsets.UpperTorso
    elseif dist < 500 then
        basePos = torso.Position + DaHoodOffsets.Torso
    else
        basePos = torso.Position + DaHoodOffsets.LowerTorso
    end

    -- Apply prediction
    if Settings.AntiDetection then
        basePos = GetPredictedPosition(basePos, vel, dist)
        basePos += Vector3.new(math.random(-6,6)/100, math.random(-6,6)/100, 0)
    else
        basePos = GetPredictedPosition(basePos, vel, dist)
    end

    return basePos
end

-- GET SMOOTHNESS / DELAY
local function GetSmoothness()
    return Settings.AntiDetection and math.clamp(Settings.BaseSmoothness + (math.random()*2-1)*Settings.SmoothnessVariation, 0.12, 0.32) or Settings.BaseSmoothness
end
local function GetShootDelay()
    return Settings.AntiDetection and math.clamp(Settings.BaseShootDelay + (math.random()*2-1)*Settings.ShootDelayVariation, 0.28, 0.65) or Settings.BaseShootDelay
end

-- SOUND FUNCTION
local function PlaySound(id, vol)
    vol = vol or 0.8
    pcall(function()
        local s = Instance.new("Sound", SoundService)
        s.SoundId = "rbxassetid://"..id
        s.Volume = vol
        s:Play()
        task.delay(8, function() pcall(function() s:Destroy() end) end)
    end)
end

-- DEATH TRIGGER
local function OnDeath(victim, dist)
    if dist > Settings.DeathMaxRange or LastProcessedDeath == victim.UserId then return end
    LastProcessedDeath = victim.UserId
    PlaySound(136263171450246, 1)
    DeathText.Visible = true
    DeathText.Text = ">:)"
    DeathText.TextColor3 = Color3.new(1,0.2,0.2)
    task.wait(3)
    PlaySound(132948338000932, 0.9)
    DeathText.Text = "sorry lol"
    DeathText.TextColor3 = Color3.new(1,1,1)
    task.wait(5)
    PlaySound(114703843022722, 0.7)
    TweenService:Create(DeathText, TweenInfo.new(1), {TextTransparency=1}):Play()
    task.wait(1.2)
    DeathText.Visible = false
    DeathText.TextTransparency = 0
end

-- FIRE WEAPON
local function FireGun()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("Remotes") or ReplicatedStorage
        local fire = remotes:FindFirstChild("FireGun") or remotes:FindFirstChild("Fire") or remotes:FindFirstChild("Shoot")
        if fire and fire:IsA("RemoteEvent") then fire:FireServer() end
        local tool = LocalCharacter:FindFirstChildOfClass("Tool")
        if tool and tool:FindFirstChild("Fire") then tool.Fire:InvokeServer() end
    end)
end
-- AUTO SHOOT
local function AutoShoot()
    if not Enabled or not Settings.AutoShootEnabled or not CurrentTarget then return end
    local hum = CurrentTarget.Humanoid
    if hum.Health <= 0 then OnDeath(CurrentTarget.Player, CurrentTarget.Distance) return end
    if CurrentTarget.Distance > Settings.ShootRange or not IsVisible(CurrentTarget.Torso) then return end
    if os.clock() - LastShootTime < GetShootDelay() then return end
    FireGun()
    LastShootTime = os.clock()
end

-- TARGET SELECTION
local function GetTarget()
    local best, bestScore = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
        local root = char:FindFirstChild("HumanoidRootPart")
        if not hum or not torso or not root or hum.Health <= 0 or hum.Health < Settings.MinTargetHP then continue end

        local dist = (Camera.CFrame.Position - torso.Position).Magnitude
        if dist > Settings.MaxDistance then continue end

        local aimPos = GetAimPoint(char, dist, root.Velocity)
        if not aimPos then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(aimPos)
        local center = Camera.ViewportSize / 2
        local fovCheck = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude <= Settings.FOVRadius
        if not onScreen or not fovCheck or not IsVisible(torso) then continue end

        local camDir = Camera.CFrame.LookVector
        local angle = math.deg(math.acos(math.clamp(camDir:Dot((aimPos - Camera.CFrame.Position).Unit), -1, 1)))
        local score = dist + angle * 1.8

        if score < bestScore then
            bestScore = score
            best = {
                Player = plr, Character = char, Humanoid = hum, Torso = torso,
                HumanoidRootPart = root, AimPos = aimPos, Distance = dist
            }
        end
    end
    return best
end

-- UPDATE STATUS + AVATAR + HEALTH BAR
local function UpdateStatus()
    if not CurrentTarget then
        StatusText.Text = "No Target"
        AvatarImage.Visible = false
        HealthBar.Visible = false
        HealthBG.Visible = false
        Glow.Enabled = false
        Triangle.Transparency = 1
        return
    end

    local plr = CurrentTarget.Player
    local hum = CurrentTarget.Humanoid
    local hp, maxHp = math.floor(hum.Health), math.floor(hum.MaxHealth)
    local hpPercent = math.clamp(hp / maxHp, 0, 1)

    -- Update Avatar
    AvatarImage.Visible = true
    AvatarImage.Image = Players:GetUserThumbnailAsync(plr.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)

    -- Update Health Bar
    HealthBG.Visible = true
    HealthBar.Visible = true
    HealthBar.Size = UDim2.new(hpPercent, 0, 1, 0)
    HealthBar.BackgroundColor3 = hpPercent > 0.6 and Color3.new(0.2,0.8,0.2) or hpPercent > 0.3 and Color3.new(0.8,0.8,0.2) or Color3.new(0.8,0.2,0.2)

    -- Update Text
    StatusText.Text = string.format(
        "🎯 VERITY | DA HOOD\nName: %s\nRange: %d studs\nHealth: %d/%d\nAim: Torso Only",
        plr.DisplayName, math.floor(CurrentTarget.Distance), hp, maxHp
    )

    -- Health Sound
    if LastHealth[plr.UserId] and LastHealth[plr.UserId] - hp >= 2 then
        PlaySound(80461265049096, 0.7)
    end
    LastHealth[plr.UserId] = hp

    -- Update Visuals
    Glow.Adornee = CurrentTarget.Character
    Glow.Enabled = true
    TriangleAngle += 2.8
    local offset = Vector3.new(math.sin(math.rad(TriangleAngle))*3.5, 2, math.cos(math.rad(TriangleAngle))*3.5)
    Triangle.CFrame = CFrame.new(CurrentTarget.Torso.Position + offset, CurrentTarget.Torso.Position)
    Triangle.Transparency = 0.25
end


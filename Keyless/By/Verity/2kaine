            TargetHighlight.OutlineTransparency = 0
            TargetHighlight.OutlineColor = Color3.new(1, 1, 1)
            TargetHighlight.Adornee = Target.Parent
            TargetHighlight.Parent = Target.Parent
        end
    end

    if Target and TargetPlayer then
        local hum = Target.Parent:FindFirstChild("Humanoid")
        if hum and hum.Health > MIN_LOCK_HP then
            UpdateTargetHUD(TargetPlayer, hum, Target)
            -- INSTANT LOCK, NO PREDICTION, NO DELAY
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Position)


-- CLEAN TRIANGLE FUNCTIONS
local function ClearTriangles()
    for _, triLines in ipairs(TargetTriangles) do
        for _, line in ipairs(triLines) do
            line:Remove()
        end
    end
    TargetTriangles = {}
end

local function Draw3DTriangle(center, radius, rot)
    local camRight = Camera.CFrame.RightVector
    local camUp = Camera.CFrame.UpVector
    local angles = {0, 2.0944, 4.1888}
    local points = {}
    for _, angle in ipairs(angles) do
        local offset = (math.cos(angle + rot) * camRight + math.sin(angle + rot) * camUp) * radius
        table.insert(points, center + offset)
    end
    local lines = {}
    for i = 1, 3 do
        local p1 = Camera:WorldToViewportPoint(points[i])
        local p2 = Camera:WorldToViewportPoint(points[i % 3 + 1])
        if p1.Z > 0 and p2.Z > 0 then
            local line = Drawing.new("Line")
            line.Color = Color3.new(1, 0, 0)
            line.Thickness = TRIANGLE_THICKNESS
            line.Transparency = 0.7
            line.From = Vector2.new(p1.X, p1.Y)
            line.To = Vector2.new(p2.X, p2.Y)
            line.Visible = true
            table.insert(lines, line)
        end
    end
    return lines
end


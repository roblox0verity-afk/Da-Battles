    TriangleAngle = TriangleAngle + Settings.TriangleSpeed
    local offset = Vector3.new(
        math.sin(math.rad(TriangleAngle)) * Settings.TriangleOrbitRadius,
        Settings.TriangleHeight,
        math.cos(math.rad(TriangleAngle)) * Settings.TriangleOrbitRadius
    )
    Triangle.CFrame = CFrame.new(root.Position + offset, root.Position)
    Triangle.Transparency = 0.3
end


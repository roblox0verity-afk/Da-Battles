            ClearTriangles()
            local time = os.clock()
            TargetTriangles = {Draw3DTriangle(Target.Position, 2.2, time * 3)}
        else
            Target = nil
            TargetPlayer = nil
            TargetHUD.Visible = false
            ClearTriangles()
            if TargetHighlight then TargetHighlight:Destroy() TargetHighlight = nil end
        end
    else
        TargetHUD.Visible = false
        ClearTriangles()
    end
end)

